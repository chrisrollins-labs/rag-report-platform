{
  "name": "rag-report-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation for retrieval-grounded, multi-source AI report generation.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
