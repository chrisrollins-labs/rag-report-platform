    "eval": "tsx evals/run.ts",
    "eval:dry": "tsx evals/run.ts --dry-run"
  },
  "dependencies": {
    "next": "15.5.4",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
