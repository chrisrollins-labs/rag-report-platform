# Copy to .env.local and fill locally. Placeholder NAMES only live here - never
# a real value. This file is committed; .env.local is gitignored. A unit test
# asserts every line here is a name=<placeholder>, so a real secret can't be
# pasted in by accident. (See SECURITY.md and tests/env-example.test.ts.)

# OpenAI-compatible chat completions endpoint (OpenAI, OpenRouter, a local
# gateway - anything that speaks the /chat/completions contract).
AI_API_BASE_URL=https://api.example-provider.com/v1
AI_API_KEY=your-api-key-here
AI_DEFAULT_MODEL=example/model-name

# Public site URL (used for absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: Postgres path (the default runtime is in-memory, zero infra) ---
# Set REPORT_STORE=postgres and bring up a local database with
# `docker compose up -d` to use the pg-backed store, the pgvector corpus, and
# row-level security. Then apply the schema with `npm run db:migrate`.
REPORT_STORE=memory
DATABASE_URL=postgres://rag:rag@localhost:5432/rag
